. "$HOME/.nvm/nvm.sh" 2>/dev/null

# 1. Svenska tecken-check (snabb, ~0.5s)
echo "Kontrollerar svenska tecken..."
npm run check:swedish --silent || {
  echo "Svenska tecken-problem hittade! Fix innan commit."
  exit 1
}

# 2. TypeScript-check BARA om .ts/.tsx-filer är staged
STAGED=$(git diff --cached --name-only --diff-filter=d | grep -E '\.(ts|tsx)$' || true)
if [ -n "$STAGED" ]; then
  echo "TypeScript-check (staged .ts/.tsx hittade)..."
  npm run typecheck --silent || {
    echo "TypeScript-fel hittade! Fix innan commit."
    exit 1
  }
fi

# 3. Docs-uppdateringscheck BARA om en done-fil är staged
bash scripts/check-docs-updated.sh || {
  echo "Done-fil saknar docs-uppdateringssektion."
  exit 1
}

# 4. Plan-commit-gate (varning, blockerar ej)
bash scripts/check-plan-commit.sh

# 5. Sprint-avslut-gate (varning, blockerar ej)
bash scripts/check-sprint-closure.sh

# 6. Review-obligatorisk-gate (BLOCKER om done-fil saknar obligatoriska reviews)
bash scripts/check-reviews-done.sh || exit 1

# 7. Branch-check (BLOCKER om kod-commit på main under aktiv story)
bash scripts/check-branch-for-story.sh || exit 1
